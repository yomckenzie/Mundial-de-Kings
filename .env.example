# ═══════════════════════════════════════════════════════════
# 🎯 CHESS KING - Mundial de Kings 2026
# Configuración de APIs deportivas
# ═══════════════════════════════════════════════════════════
#
# 📡 FUENTES DE DATOS (usa las que quieras):
#
# 1️⃣ football-data.org (GRATIS ✅)
#    - Resultados automáticos post-partido
#    - 10 requests/minuto
#    - Regístrate gratis: https://www.football-data.org/
#    - Sin tarjeta de crédito
#
# 2️⃣ API-Football (PAGA ~$19/mes 💰)
#    - Live scores en tiempo real
#    - Mundial 2026 completo
#    - Regístrate: https://rapidapi.com/api-sports/api/api-football/pricing
#    - Plan Free solo tiene datos hasta 2022
#
# 3️⃣ Manual (SIEMPRE ✅)
#    - Admin ingresa resultados desde el panel
#    - No necesita configuración
# ═══════════════════════════════════════════════════════════

# ─── Opción 1: football-data.org (GRATIS) ───
# Obtén tu key: https://www.football-data.org/client/register
VITE_FOOTBALL_DATA_KEY=

# ─── Opción 2: API-Football (PAGA) ───
# Obtén tu key: https://rapidapi.com/api-sports/api/api-football/pricing
VITE_RAPIDAPI_KEY=

# ─── Supabase (Base de datos remota) ───
# Obtén tus keys: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
